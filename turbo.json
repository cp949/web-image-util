{
  "$schema": "https://v2-9-7.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "llm.txt", ".next/**", "!.next/cache/**"],
      "env": ["NODE_ENV"]
    },
    "build:watch": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint:fix": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.ts", "tests/**/*.ts", "vitest.config.*"]
    },
    "test:node": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.ts", "tests/**/*.ts", "vitest.node.config.*"]
    },
    "test:contract": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "llm.txt", "coverage/contract/**", "test-results/**"],
      "inputs": ["src/**/*.ts", "tests/**/*.ts", "scripts/**/*.mjs", "package.json", "tsup.config.ts", "vitest.contract.config.*"]
    },
    "test:package-subpath": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:ui": {
      "cache": false,
      "persistent": true
    },
    "test:browser": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "package": {
      "dependsOn": ["build"],
      "outputs": ["dist/**", "llm.txt"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
