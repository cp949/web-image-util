{
  "name": "@cp949/web-image-util-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Web image utilities monorepo",
  "type": "module",
  "repository": "https://github.com/cp949/web-image-util.git",
  "author": "cp949 <cp949@naver.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "turbo run build --filter=@cp949/web-image-util",
    "build:watch": "turbo run build:watch",
    "package": "turbo run package",
    "publish:npm": "pnpm --filter @cp949/web-image-util package && cd sub/web-image-util && npm publish --access=public",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:node": "turbo run test:node",
    "test:scripts": "vitest run --config vitest.scripts.config.ts",
    "test:package-subpath": "turbo run test:package-subpath --filter=@cp949/web-image-util",
    "test:ui": "turbo run test:ui",
    "test:browser": "turbo run test:browser",
    "test:coverage": "turbo run test:coverage",
    "verify:ci": "pnpm test:scripts && turbo run typecheck lint format:check test:node test:contract",
    "verify:release": "node ./scripts/verify-release.mjs",
    "dev": "turbo run build:watch",
    "dev:exam": "pnpm --filter @cp949/exam dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.4",
    "cross-env": "^10.1.0",
    "jest-image-snapshot": "^6.5.2",
    "playwright": "^1.59.1",
    "rimraf": "^6.1.3",
    "shelljs": "^0.10.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "turbo": "^2.9.7",
    "typescript": "^6.0.2",
    "vite": "7.3.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.13",
      "vite": "7.3.2"
    }
  }
}
