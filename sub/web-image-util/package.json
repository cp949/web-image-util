{
  "name": "@cp949/web-image-util",
  "version": "2.0.24",
  "description": "simple web image utils",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": "https://github.com/cp949/web-image-util.git",
  "author": "cp949 <cp949@naver.com>",
  "license": "MIT",
  "homepage": "https://github.com/cp949/web-image-util.git",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "package": "pnpm build",
    "clean": "rimraf dist",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "format:check": "biome format src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest --config vitest.node.config.ts",
    "test:node": "vitest --config vitest.node.config.ts",
    "test:contract": "vitest --config vitest.contract.config.ts",
    "test:security": "vitest --config tests/security/vitest.config.ts",
    "test:security:coverage": "vitest --coverage --config tests/security/vitest.config.ts",
    "test:ui": "vitest --ui",
    "test:browser": "vitest --browser",
    "test:coverage": "vitest --coverage",
    "test:coverage:contract": "vitest --coverage --config vitest.contract.config.ts",
    "test:wsl": "vitest --config vitest.wsl.config.ts",
    "test:wsl:ui": "vitest --config vitest.wsl.config.ts --ui",
    "test:wsl:coverage": "vitest --config vitest.wsl.config.ts --coverage",
    "test:types": "vitest --config vitest.wsl.config.ts tests/unit/types",
    "typecheck:wsl": "tsc --noEmit --project tsconfig.json"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.4",
    "canvas": "^3.2.3",
    "happy-dom": "^20.9.0",
    "jest-image-snapshot": "^6.5.2",
    "playwright": "^1.59.1",
    "rimraf": "^6.1.3",
    "shelljs": "^0.10.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./advanced": {
      "import": "./dist/advanced-index.js",
      "types": "./dist/advanced-index.d.ts"
    },
    "./presets": {
      "import": "./dist/presets/index.js",
      "types": "./dist/presets/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./filters": {
      "import": "./dist/filters/plugins/index.js",
      "types": "./dist/filters/plugins/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ]
}
