{
  "name": "@cp949/web-image-util",
  "version": "2.0.33",
  "description": "simple web image utils",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": "https://github.com/cp949/web-image-util.git",
  "author": "cp949 <cp949@naver.com>",
  "license": "MIT",
  "homepage": "https://github.com/cp949/web-image-util.git",
  "scripts": {
    "build": "tsup && node ./scripts/generate-llm-txt.mjs",
    "build:watch": "tsup --watch",
    "package": "pnpm build",
    "clean": "rimraf dist llm.txt",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "format:check": "biome format src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest --config vitest.node.config.ts",
    "test:node": "vitest --config vitest.node.config.ts",
    "test:contract": "pnpm build && vitest --config vitest.contract.config.ts",
    "test:security": "vitest --config tests/security/vitest.config.ts",
    "test:security:coverage": "vitest --coverage --config tests/security/vitest.config.ts",
    "test:package-subpath": "node --input-type=module -e \"const mod = await import('@cp949/web-image-util/svg-sanitizer'); if (typeof mod.sanitizeSvgStrict !== 'function' || typeof mod.sanitizeSvgStrictDetailed !== 'function') throw new Error('svg-sanitizer subpath export smoke failed');\"",
    "test:ui": "vitest --ui",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.node.config.ts",
    "test:coverage:contract": "pnpm build && vitest --coverage --config vitest.contract.config.ts",
    "test:types": "vitest --config vitest.node.config.ts tests/unit/types"
  },
  "dependencies": {
    "dompurify": "^3.4.2"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "canvas": "^3.2.3",
    "happy-dom": "^20.9.0",
    "jest-image-snapshot": "^6.5.2",
    "playwright": "^1.59.1",
    "rimraf": "^6.1.3",
    "shelljs": "^0.10.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "8.0.10",
    "vitest": "^4.1.5"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./advanced": {
      "import": "./dist/advanced-index.js",
      "types": "./dist/advanced-index.d.ts"
    },
    "./presets": {
      "import": "./dist/presets/index.js",
      "types": "./dist/presets/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./filters": {
      "import": "./dist/filters/plugins/index.js",
      "types": "./dist/filters/plugins/index.d.ts"
    },
    "./svg-sanitizer": {
      "import": "./dist/svg-sanitizer/index.js",
      "types": "./dist/svg-sanitizer/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "llm.txt"
  ]
}
